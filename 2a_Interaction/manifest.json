{
  "manifest_version": 2,
  "name": "Swords and Ravens GOT Assistant",
  "version": "1.0",
  "icons": {
    "48": "raven.svg",
    "96": "raven.svg"
  },
  "browser_action": {
    "default_popup": "UI.html",
    "default_icon": "raven.svg"
  },
"permissions": [
    "*://swordsandravens.net/*",
    "http://127.0.0.1:5002/",
    "https://got.chenevertsoftwareservices.com/"
  ],
  "web_accessible_resources": ["injectionScript.js"],
  "content_scripts": [
  {
    "matches": ["*://swordsandravens.net/play/*"],
    "js": ["ActiveWindowScript.js"],
    "run_at": "document_idle"
  }
]
}